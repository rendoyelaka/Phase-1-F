<?xml version="1.0" encoding="utf-8"?>
<!--
    Play Store-style install screen — Design C
    IDs used by InstallActivity.kt:
      tv_rating, tv_size, tv_review_count, tv_downloads,
      install_button, install_button_progress, tv_install_label,
      tv_under_button,
      dots_container,
      layout_downloading, tv_dl_status, progress_bar_install,
      layout_installing, progress_bar_installing,
      layout_error, btn_retry, btn_cancel,
      layout_play_protect, layout_updated,
      reviews_container,
      tv_toast
-->
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- Scrollable main content -->
    <ScrollView
        android:id="@+id/scroll_main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── Rating + size row ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:paddingBottom="0dp"
                android:gravity="center_vertical">

                <!-- Star rating (static image drawn in code) -->
                <LinearLayout
                    android:id="@+id/star_row"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical" />

                <TextView
                    android:id="@+id/tv_rating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="4.5"
                    android:textColor="#5F6368"
                    android:textSize="11sp"
                    android:layout_marginStart="6dp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/tv_size"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1.84 MB · Free"
                    android:textColor="#9AA0A6"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- ── Stats row: reviews | parental | downloads ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:paddingBottom="0dp"
                android:gravity="center_vertical">

                <!-- Reviews -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="4.5★"
                        android:textColor="#202124"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_review_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="17M reviews"
                        android:textColor="#5F6368"
                        android:textSize="9sp" />
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="1dp"
                    android:layout_height="28dp"
                    android:background="#E0E0E0" />

                <!-- Parental -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔞"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Parental\nguidance"
                        android:textColor="#5F6368"
                        android:textSize="9sp"
                        android:gravity="center"
                        android:lineSpacingMultiplier="1.1" />
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="1dp"
                    android:layout_height="28dp"
                    android:background="#E0E0E0" />

                <!-- Downloads -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tv_downloads"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1M+"
                        android:textColor="#202124"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Downloads"
                        android:textColor="#5F6368"
                        android:textSize="9sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Separator -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="10dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:background="#F1F3F4" />

            <!-- ── Install button ── -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="10dp">

                <!-- Background (idle/done solid) -->
                <View
                    android:id="@+id/install_button_bg"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:background="@drawable/btn_install_bg" />

                <!-- Progress fill layer with white label clipped inside it -->
                <FrameLayout
                    android:id="@+id/install_button_progress"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:background="@drawable/btn_install_progress"
                    android:clipChildren="true"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/tv_install_label_white"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical"
                        android:gravity="center"
                        android:text="Install"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </FrameLayout>

                <!-- Clickable overlay (no label here - white label inside blue fill handles it) -->
                <FrameLayout
                    android:id="@+id/install_button"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:background="@android:color/transparent"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:id="@+id/tv_install_label"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical"
                        android:gravity="center"
                        android:text="Install"
                        android:textColor="#1A73E8"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:visibility="gone" />
                </FrameLayout>
            </FrameLayout>

            <!-- ── Under-button status area ── -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="18dp"
                android:layout_marginTop="6dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp">

                <!-- Play Protect badge (idle) -->
                <LinearLayout
                    android:id="@+id/layout_play_protect"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:visibility="visible">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_play_protect" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Verified by Play Protect"
                        android:textColor="#202124"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:layout_marginStart="5dp" />
                </LinearLayout>

                <!-- Downloading text -->
                <TextView
                    android:id="@+id/tv_under_button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:textColor="#5F6368"
                    android:textSize="10sp"
                    android:visibility="gone" />

                <!-- Last updated (done) -->
                <TextView
                    android:id="@+id/layout_updated"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="Last updated: Today"
                    android:textColor="#34A853"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:visibility="gone" />
            </FrameLayout>

            <!-- ── Dots container ── -->
            <FrameLayout
                android:id="@+id/dots_container"
                android:layout_width="160dp"
                android:layout_height="200dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp" />

            <!-- ── Bottom pipeline UI ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:paddingTop="0dp">

                <!-- DOWNLOADING section -->
                <LinearLayout
                    android:id="@+id/layout_downloading"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">


                </LinearLayout>

                <!-- INSTALLING section -->
                <LinearLayout
                    android:id="@+id/layout_installing"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">


                </LinearLayout>

                <!-- ERROR section -->
                <LinearLayout
                    android:id="@+id/layout_error"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Download failed. Check your connection."
                        android:textColor="#D93025"
                        android:textSize="11sp"
                        android:layout_marginBottom="10dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <Button
                            android:id="@+id/btn_retry"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:text="Retry"
                            android:textColor="#FFFFFF"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:background="@drawable/btn_retry_bg" />

                        <Button
                            android:id="@+id/btn_cancel"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:text="Cancel"
                            android:textColor="#202124"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:background="@drawable/btn_cancel_bg" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Google Play branding -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginTop="16dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_google_play"
                        android:contentDescription="@null"
                        android:layout_marginEnd="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Google Play"
                        android:textColor="#202124"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>
            </LinearLayout>

            <!-- Separator before reviews -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F1F3F4" />

            <!-- ── Reviews section ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:paddingTop="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ratings &amp; reviews"
                    android:textColor="#202124"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <!-- Reviews inserted programmatically -->
                <LinearLayout
                    android:id="@+id/reviews_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Toast overlay -->
    <TextView
        android:id="@+id/tv_toast"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="16dp"
        android:background="@drawable/toast_bg"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:textColor="#FFFFFF"
        android:textSize="11sp"
        android:visibility="gone" />

</RelativeLayout>
